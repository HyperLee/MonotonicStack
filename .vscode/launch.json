{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (Demo)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-demo",
            "program": "${workspaceFolder}/src/MonotonicStack.Demo/bin/Debug/net10.0/MonotonicStack.Demo.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MonotonicStack.Demo",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Launch (Demo, external console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-demo",
            "program": "${workspaceFolder}/src/MonotonicStack.Demo/bin/Debug/net10.0/MonotonicStack.Demo.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MonotonicStack.Demo",
            "console": "externalTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Test Debug (xUnit)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tests",
            "program": "/usr/local/share/dotnet/dotnet",
            "args": [
                "test",
                "${workspaceFolder}/tests/MonotonicStack.Tests/MonotonicStack.Tests.csproj",
                "--no-build"
            ],
            "cwd": "${workspaceFolder}/tests/MonotonicStack.Tests",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "VSTEST_HOST_DEBUG": "1"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
